{
  "name": "admission-fit-checker",
  "version": "0.1.0",
  "description": "Local-first portfolio MVP that compares an academic profile against university program requirements and returns a source-aware admission fit verdict.",
  "homepage": "https://admission-fit-checker.vercel.app/",
  "keywords": [
    "local-first",
    "react",
    "vite",
    "typescript",
    "indexeddb",
    "pdfjs",
    "byok",
    "university-admissions",
    "portfolio"
  ],
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.0.11",
    "lucide-react": "^0.468.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "tesseract.js": "^5.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
